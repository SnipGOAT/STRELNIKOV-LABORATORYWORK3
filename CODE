    print("\n2. Простые числа (до 50):")
    primes = list(prime_generator(50))
    print(f"   Результат: {primes}")
    print(f"   Количество простых чисел: {len(primes)}")

    # Демонстрация контейнера для коллекции книг
    print("\n3. Коллекция книг (перебор в цикле):")
    library = BookCollection()
    library.add_book(Book("Интенсивный курс Python", "Эрик Маттес"))
    library.add_book(Book("Искусственный интеллект: современный подход", "Стюарт Рассел, Питер Норвиг"))
